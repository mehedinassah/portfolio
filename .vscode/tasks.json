{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "frontend: start",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "fullstack"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "ERROR in (.*)",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the development server",
          "endsPattern": "Compiled successfully"
        }
      }
    },
    {
      "label": "backend: start",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "fullstack"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "ERROR (.*)",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting PortfolioApplication",
          "endsPattern": "Started PortfolioApplication"
        }
      }
    },
    {
      "label": "🎯 Run Full Stack",
      "dependsOn": ["frontend: start", "backend: start"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
